{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Astro: Dev Server",
      "type": "shell",
      "command": "npx astro dev",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Astro: Build",
      "type": "shell",
      "command": "npx astro build",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Deploy to overstegerstudios.com",
      "type": "shell",
      "command": "rsync -avz --delete ./dist/ hopperwiki:/home/hopperwi/overstegerstudios.com/",
      "dependsOn": "Astro: Build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
