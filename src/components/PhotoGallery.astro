---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface GalleryImage {
  image: ImageMetadata;
  alt: string;
  caption?: string;
}

interface Props {
  images: GalleryImage[];
  galleryId?: string;
}

const { images, galleryId = 'photo-gallery' } = Astro.props;

const items = await Promise.all(
  images.map(async ({ image, alt, caption }) => {
    const full = await getImage({ src: image, width: 1800, format: 'webp', quality: 82 });
    return { image, alt, caption, fullSrc: full.src };
  }),
);
---

<div class="photo-gallery">
  {items.map(({ image, alt, caption, fullSrc }) => (
    <a
      href={fullSrc}
      class="photo-gallery-item glightbox"
      data-gallery={galleryId}
      data-title={caption}
    >
      <Image
        src={image}
        alt={alt}
        widths={[320, 640, 960]}
        sizes="(max-width: 740px) 50vw, (max-width: 1280px) 33vw, 25vw"
        format="webp"
        quality={80}
        loading="lazy"
      />
    </a>
  ))}
</div>

<script>
  import GLightbox from 'glightbox';
  import 'glightbox/dist/css/glightbox.min.css';

  function initPhotoGalleries() {
    const lightbox = GLightbox({
      selector: '.glightbox',
      touchNavigation: true,
      loop: true,
      zoomable: true,
      draggable: true,
    });
    return lightbox;
  }

  let current = initPhotoGalleries();

  document.addEventListener('astro:page-load', () => {
    current?.destroy?.();
    current = initPhotoGalleries();
  });
</script>

<style>
  .photo-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.75rem;
    margin: 2rem 0;
    position: relative;
    width: 90vw;
    max-width: 1600px;
    min-width: 100%;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    transform: translateX(calc(50vw - 50%));
  }

  .photo-gallery-item {
    display: block;
    overflow: hidden;
    border-radius: var(--radius);
    aspect-ratio: 4 / 3;
  }

  .photo-gallery-item :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .photo-gallery-item:hover :global(img) {
    transform: scale(1.05);
  }

  /* Lightbox caption — GLightbox injects its markup into <body> at runtime,
     outside this component's tree, so these rules target its classes globally.
     GLightbox already keeps `.gslide-description` sized to track the image
     width via an inline max-width (it's a flex sibling of the image, not a
     child, so it can't be absolutely overlaid on top of it) — we just restyle
     it from the default white bar into a dark plate that sits under the photo. */
  :global(.gslide-description) {
    background: rgba(10, 10, 10, 0.92) !important;
    pointer-events: none;
  }

  :global(.gdesc-open .gslide-media) {
    opacity: 1 !important;
  }

  :global(.gdesc-inner) {
    padding: 1.6rem 2rem !important;
  }

  :global(.gslide-title) {
    margin: 0 !important;
    color: #fff !important;
    font-family: var(--font-serif) !important;
    font-size: 1.6rem !important;
    font-weight: 400 !important;
    line-height: 1.5 !important;
    text-align: left !important;
  }

  @media (max-width: 500px) {
    :global(.gdesc-inner) {
      padding: 1.2rem 1.2rem !important;
    }

    :global(.gslide-title) {
      font-size: 1.4rem !important;
    }
  }
</style>
