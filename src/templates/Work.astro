---
import Layout from '../layouts/Layout.astro';
import PhotoGallery from '../components/PhotoGallery.astro';
import { type CollectionEntry } from 'astro:content';
import type { ImageMetadata } from 'astro';

interface Props {
  entry: CollectionEntry<'work'> | CollectionEntry<'news'> | CollectionEntry<'sold'>;
  next?: any;
  prev?: any;
  baseSlug?: string; // e.g. 'work'
}

const { entry, next, prev, baseSlug } = Astro.props;
const { Content } = await entry.render();

const { title, description, thumbnail, thumbnail_caption, external_url, gallery_captions } = entry.data;

// Project pages can have a photo gallery living at src/images/gallery/<slug>/.
// If a matching folder exists, its images become the page's main gallery.
const galleryModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/images/gallery/*/*.{jpg,jpeg,png}',
  { eager: true },
);

function labelFromFilename(path: string) {
  const filename = path.split('/').pop() ?? '';
  const base = filename.replace(/\.[^.]+$/, '');
  const [date, location] = base.split('-');
  const place = (location ?? base).replace(/_/g, ' ');
  if (date && /^\d{8}$/.test(date)) {
    const year = date.slice(0, 4);
    const month = date.slice(4, 6);
    const monthName = new Date(Number(year), Number(month) - 1).toLocaleString('en-US', { month: 'long' });
    return `${place} — ${monthName} ${year}`;
  }
  return place;
}

const galleryImages = Object.entries(galleryModules)
  .filter(([path]) => path.includes(`/gallery/${entry.slug}/`))
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([path, mod]) => {
    const filename = path.split('/').pop() ?? '';
    const caption = gallery_captions?.[filename] ?? labelFromFilename(path);
    return { image: mod.default, alt: caption };
  });
---

<Layout title={title} description={description}>
  <article class={`post-content ${thumbnail ? '' : 'no-image'}`}>
    {/* Title hidden as it is shown in the header now
    <header class="post-content-header">
      <h1 class="post-content-title">{title}</h1>
    </header>
    */}

    {description && (
      <p class="post-content-excerpt">{description}</p>
    )}

    {thumbnail && (
      <div class="post-content-image">
        {external_url ? (
          <a href={external_url} target="_blank" rel="noopener noreferrer">
            <img src={thumbnail} class="kg-image" alt={title} />
          </a>
        ) : (
          <img src={thumbnail} class="kg-image" alt={title} />
        )}
        {thumbnail_caption && (
          <p class="post-content-image-caption" set:html={thumbnail_caption} />
        )}
      </div>
    )}

    <div class="post-content-body">
      <Content />
    </div>

    {galleryImages.length > 0 && (
      <PhotoGallery images={galleryImages} galleryId={entry.slug} />
    )}

    <div class="post-link">
      <div>
        {next && (
            <a style="display: flex; align-items: center; color: #131313; font-size: 2rem;" href={`/${baseSlug}/${next.slug}`}>
               <span>&larr; {next.data.title}</span>
            </a>
        )}
      </div>
      <div>
        {prev && (
            <a style="display: flex; align-items: center; color: #131313; font-size: 2rem;" href={`/${baseSlug}/${prev.slug}`}>
               <span>{prev.data.title} &rarr;</span>
            </a>
        )}
      </div>
    </div>

  </article>
</Layout>

<style>
  .post-content-image-caption {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    margin: 0;
    padding: 3rem 2rem 1.4rem;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.55), transparent);
    color: #fff;
    font-family: var(--font-serif);
    font-size: 1.5rem;
    line-height: 1.4;
    text-align: right;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.35s ease, transform 0.35s ease;
    pointer-events: none;
  }

  .post-content-image:hover .post-content-image-caption,
  .post-content-image:focus-within .post-content-image-caption {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 500px) {
    .post-content-image-caption {
      opacity: 1;
      transform: translateY(0);
      font-size: 1.3rem;
      padding: 2.5rem 1.2rem 1rem;
    }
  }
</style>
