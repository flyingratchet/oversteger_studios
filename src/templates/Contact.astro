---
import Layout from '../layouts/Layout.astro';
import { type CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'pages'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const { title, description, thumbnail } = entry.data;

// Submits directly to Formspree (https://formspree.io/f/myznygzl) — no
// site-side backend needed. Plain HTML POST + _next redirect, no JS hijack.
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/myznygzl';
---

<Layout title={title} description={description}>
  <article class="contact-form page-template">
    {thumbnail && (
      <div class="post-content-image">
        <img src={thumbnail} class="kg-image" alt={title} />
      </div>
    )}

    <div class="post-content-body">
      <Content />

      <h3 id="forms">Form</h3>
      <form action={FORMSPREE_ENDPOINT} method="POST" class="contact-form">
        <input type="hidden" name="_subject" value="New message from Oversteger Studios" />
        <input type="hidden" name="_next" value="/contact/thanks" />
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="row gtr-uniform">
          <div class="col-6 col-12-xsmall">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" autocomplete="name" required />
          </div>
          <div class="col-6 col-12-xsmall">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" autocomplete="email" required />
          </div>

          <div class="col-12">
            <label for="reason">Reason for contact</label>
            <select id="reason" name="reason">
              <option value="General inquiry">General inquiry</option>
              <option value="Project collaboration">Project collaboration</option>
              <option value="Website or tool issue">Website or tool issue</option>
              <option value="Media or image request">Media or image request</option>
              <option value="Donation or support question">Donation or support question</option>
            </select>
          </div>

          <div class="col-12">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="7" required></textarea>
          </div>

          <div class="col-12">
            <ul class="actions">
              <li>
                <button type="submit" class="primary">Send message</button>
              </li>
            </ul>
          </div>
        </div>
      </form>
    </div>
  </article>
</Layout>
