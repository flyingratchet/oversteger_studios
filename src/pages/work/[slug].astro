---
import { getCollection } from 'astro:content';
import WorkTemplate from '../../templates/Work.astro';

export async function getStaticPaths() {
  // Entries flagged `do_not_show` are excluded entirely: no page is built for
  // them (direct links 404), and they're skipped when computing prev/next so
  // neighboring pages automatically bridge across the gap.
  const workEntries = (await getCollection('work')).filter((entry) => !entry.data.do_not_show);

  // Match the ordering used on the home page grid (src/pages/index.astro),
  // which sorts by the `number` frontmatter field, not by date.
  const sortedEntries = workEntries.sort((a, b) => {
    const numA = a.data.number || 9999;
    const numB = b.data.number || 9999;
    return numA - numB;
  });

  return sortedEntries.map((entry, index) => {
    // Work.astro renders `next` on the left (←) and `prev` on the right (→),
    // so with ascending number order: left goes to the lower number, right to the higher one.
    const next = index === 0 ? null : sortedEntries[index - 1];
    const prev = index === sortedEntries.length - 1 ? null : sortedEntries[index + 1];

    return {
      params: { slug: entry.slug },
      props: {
        entry,
        next,
        prev,
      },
    };
  });
}

const { entry, next, prev } = Astro.props;
---

<WorkTemplate entry={entry} next={next} prev={prev} baseSlug="work" />
